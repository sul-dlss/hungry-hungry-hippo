<%= tag.div %>
  <%= render Elements::Forms::LabelComponent.new(form:, field_name:, label_text: label, hidden_label:, default_label_class: 'form-check-label') %>
  <%= tag.div class: 'button-group' role: 'group'>
    <%= render Elements::Forms::LabelComponent.new(form:, field_name:, label_text: options.first, hidden_label:, default_label_class: 'form-check-label') %>
    <%= form.radio_button field_name, options.first, class: 'form-check-input' %>
    <%= render Elements::Forms::LabelComponent.new(form:, field_name:, label_text: options.last, hidden_label:, default_label_class: 'form-check-label') %>
    <%= form.radio_button field_name, options.last, class: 'form-check-input' checked%>
  <% end %>
  <%= render Elements::Forms::InvalidFeedbackComponent.new(form:, field_name:) %>
<% end %>
