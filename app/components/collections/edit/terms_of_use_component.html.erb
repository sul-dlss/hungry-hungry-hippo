<div class="pane-section" data-controller="radio-textarea">
  <%= render Elements::Forms::FieldsetComponent.new(label: helpers.t('collections.edit.panes.terms_of_use.use_statement_label')) do %>
    <div class="form-check">
      <%= form.radio_button :custom_rights_statement_option, 'no', class: 'form-check-input', data: { action: 'input->radio-textarea#toggleTextAreas' } %>
      <%= form.label :custom_rights_statement_option_no, helpers.t('collections.edit.panes.terms_of_use.use_statement_options.nope'), class: 'form-check-label' %>
    </div>
    <div class="form-check pt-2">
      <%= form.radio_button :custom_rights_statement_option, 'provided', class: 'form-check-input', data: { action: 'input->radio-textarea#toggleTextAreas' } %>
      <%= form.label :custom_rights_statement_option_provided, helpers.t('collections.edit.panes.terms_of_use.use_statement_options.provided'), class: 'form-check-label' %>
      <%= form.text_area :provided_custom_rights_statement, class: 'form-control my-3', rows: 2, disabled: true %>
    </div>
    <div class="form-check pt-2">
      <%= form.radio_button :custom_rights_statement_option, 'depositor_selects', class: 'form-check-input', data: { action: 'input->radio-textarea#toggleTextAreas' } %>
      <%= form.label :custom_rights_statement_option_depositor_selects, helpers.t('collections.edit.panes.terms_of_use.use_statement_options.depositor_selects'), class: 'form-check-label' %>
      <%= form.text_area :custom_rights_statement_instructions, class: 'form-control my-3', rows: 2, value: helpers.t('terms_of_use.default_use_statement_instructions'), disabled: true %>
    </div>
  <% end %>
</div>
