<%= render Elements::Tables::TableComponent.new(id: 'deposits-table', classes: 'mb-5',
                                                label: 'Deposits for this collection', show_label: false,
                                                empty_message:) do |component| %>
  <% component.with_headers([
                              { label: 'Deposit' },
                              { label: 'Deposit Status' },
                              { label: 'Owner' },
                              { label: 'Last Modified' },
                              { label: t('collections.fields.sharing_link.label'), tooltip: t('collections.fields.sharing_link.tooltip_html') }
                            ]) %>
  <% component.with_rows(collection_deposits) %>
<% end %>
<%= helpers.paginate presenters %>
