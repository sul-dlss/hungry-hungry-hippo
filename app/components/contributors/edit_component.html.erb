
<%= tag.div data: { controller: 'contributors' } do %>
  <%= render Elements::Forms::ToggleComponent.new(form:, field_name: :role_type,
                                                  label: t('works.edit.fields.contributors.role_type.label'),
                                                  options: role_type_options) %>
  <%= render Elements::Forms::SelectFieldComponent.new(form:, field_name: :person_role,
                                                       options: PERSON_ROLES, label: t('works.edit.fields.contributors.role.label'),
                                                       data: { contributors_target: 'selectPersonRole' }) %>
  <%= render Elements::Forms::SelectFieldComponent.new(form:, field_name: :organization_role,
                                                       options: ORGANIZATION_ROLES, label: t('works.edit.fields.contributors.role.label'),
                                                       data: { contributors_target: 'selectOrganizationRole' }) %>

  <!-- Contributor person name/orcid fields -->
  <%= tag.div data: { contributors_target: 'personName' } do %>
    <%= render Elements::Forms::LabelComponent.new(form:, field_name: :with_orcid, label_text: t('works.edit.fields.contributors.orcid_or_name.label')) %><br>
    <%= tag.div class: 'form-check' do %>
      <%= form.radio_button :with_orcid, true, class: 'form-check-input' %>
      <%= form.label :with_orcid_true, 'ORCID iD', class: 'form-check-label' %>
      <%= render Elements::Forms::TextFieldComponent.new(form:, field_name: :orcid, hidden_label: true) %>
    <% end %>
    <%= tag.div class: 'form-check' do %>
      <%= form.radio_button :with_orcid, false, class: 'form-check-input' %>
      <%= form.label :with_orcid_false, 'Name', class: 'form-check-label' %>
      <!-- author name fields -->
    <% end %>
    <%= render Elements::Forms::InvalidFeedbackComponent.new(form:, field_name: :with_orcid) %>
    <%= tag.div class: 'row' do %>
      <%= tag.div class: 'col' do %>
        <%= render Elements::Forms::TextFieldComponent.new(form:, field_name: :first_name, label: t('works.edit.fields.contributors.first_name.label')) %>
      <% end %>
      <%= tag.div class: 'col' do %>
        <%= render Elements::Forms::TextFieldComponent.new(form:, field_name: :last_name, label: t('works.edit.fields.contributors.last_name.label')) %>
      <% end %>
    <% end %>
  <% end %>

  <!-- Contributor organization name field -->
  <%= tag.div class: 'row', data: { contributors_target: 'organizationName' } do %>
    <%= render Elements::Forms::TextFieldComponent.new(form:, field_name: :organization_name, label: t('works.edit.fields.contributors.organization.label')) %>
  <% end %>
<% end %>
