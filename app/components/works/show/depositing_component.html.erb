<% if alert? %>
  <%= render SdrViewComponents::Elements::AlertComponent.new(variant: :success, dismissible: true,
                                                             title: t('messages.deposit_submitted'),
                                                             data: { turbo_permanent: true }, id: 'depositing-alert') do %>
    <%= t('messages.deposit_submitted_note_html') %>
  <% end %>
<% else %>
  <%# This is so that when the page morphs, the alert is permanent. %>
  <div id="depositing-alert" data-turbo-permanent="true"></div>
<% end %>
