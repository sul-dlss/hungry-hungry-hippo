<%= render Elements::Forms::TextareaFieldComponent.new(form:, field_name: :title, label: t('work_form.fields.title.label'), tooltip: t('work_form.fields.title.tooltip_html'),
                                                       help_text: t('work_form.fields.title.help_text'), width: 500, rows: 1, container_classes: 'pane-section', mark_required: true, label_classes: 'fw-bold') %>
<%= render NestedComponentPresenter.for(form:, field_name: :contact_emails, model_class: ContactEmailForm, form_component: Works::Edit::ContactEmailsComponent,
                                        bordered: false, single_field: true, fieldset_classes: 'pane-section',
                                        label_text: contact_emails_label_text, mark_required: mark_contact_emails_required?) %>

<% if works_contact_email? %>
  <%= form.hidden_field :works_contact_email %>

  <div class="pane-section">
    <p>
      Contact email provided by collection manager <%= render SdrViewComponents::Elements::TooltipComponent.new(target_label: 'Provided contact email', tooltip: t('work_form.fields.works_contact_email.tooltip_html')) %>
    </p>
    <p>
      <%= works_contact_email %>
    </p>
  </div>
<% end %>
