<div data-controller="work-type" data-work-type-tab-error-outlet=".tab-error">
  <div class="pane-section">
    <%= render Elements::Forms::FieldsetComponent.new(label: t('work_form.fields.work_type.label'), tooltip: t('work_form.fields.work_type.tooltip_html'), mark_required: !readonly?) do %>
      <% if readonly? %>
        <p>The collection manager has selected "<%= work_type %>" as the type for all deposits.</p>
        <%= form.hidden_field :work_type, data: { work_type_target: 'workTypeHidden' } %>
      <% else %>
        <div class="types-container">
          <%= render Elements::Forms::InputCollectionRadioButtonsComponent.new(form:, field_name: :work_type, input_collection: WorkType.all, input_data: { work_type_target: 'workTypeRadio', action: 'work-type#showSubtypes click->tooltips#hideAll' }, mark_required: true) %>
        </div>
      <% end %>
    <% end %>
  </div>

  <%# Text subtypes %>
  <%= render Edit::WorkSubtypesComponent.new(form:, work_type: 'Text', more_options: true, label:, tooltip:, required_subtypes:, legend_classes:) %>

  <%# Data subtypes %>
  <%= render Edit::WorkSubtypesComponent.new(form:, work_type: 'Data', more_options: true, label:, tooltip:, required_subtypes:, legend_classes:) %>

  <%# Software, multimedia subtypes %>
  <%= render Edit::WorkSubtypesComponent.new(form:, work_type: 'Software/Code', more_options: true, label:, tooltip:, required_subtypes:, legend_classes:) %>

  <%# Image %>
  <%= render Edit::WorkSubtypesComponent.new(form:, work_type: 'Image', more_options: true, label:, tooltip:, required_subtypes:, legend_classes:) %>

  <%# Sound %>
  <%= render Edit::WorkSubtypesComponent.new(form:, work_type: 'Sound', more_options: true, label:, tooltip:, required_subtypes:, legend_classes:) %>

  <%# Video %>
  <%= render Edit::WorkSubtypesComponent.new(form:, work_type: 'Video', more_options: true, label:, tooltip:, required_subtypes:, legend_classes:) %>

  <%# Music %>
  <%= render Edit::WorkSubtypesComponent.new(form:, work_type: 'Music', more_options: true, label:, tooltip:, required_subtypes:,
                                             minimum_terms: WorkType::MINIMUM_REQUIRED_MUSIC_SUBTYPES, error_field_name: :work_subtypes_music, legend_classes:) %>

  <%# Mixed materials %>
  <%= render Edit::WorkSubtypesComponent.new(form:, work_type: 'Mixed Materials', label:, tooltip:, required_subtypes:,
                                             minimum_terms: WorkType::MINIMUM_REQUIRED_MIXED_MATERIAL_SUBTYPES, error_field_name: :work_subtypes_mixed_materials, legend_classes:) %>

  <%# Other %>
  <%= render Edit::WorkSubtypesComponent.new(form:, work_type: 'Other', label:, tooltip:, legend_classes:) do %>
    <%= render Elements::Forms::TextFieldComponent.new(form:, field_name: :other_work_subtype, label: 'Description for "Other"', mark_required: true) %>
  <% end %>

  <% required_subtypes.each do |subtype| %>
    <%= form.hidden_field :work_subtypes, value: subtype, multiple: true %>
  <% end %>
</div>
