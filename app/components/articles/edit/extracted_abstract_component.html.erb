<% if abstract.present? %>
  <%= form.hidden_field :extracted_abstract, value: @abstract %>
  <div>
    <p class="magic-blue"><%= helpers.magic_icon(classes: 'me-2') %><%= t('article_form.messages.extract_abstract.complete') %></p>
    <div class="d-flex align-items-start justify-content-between gap-3">
      <p class="mb-0"><%= @abstract %></p>
      <%= render Elements::IconButtonLinkComponent.new(link: clear_abstracts_path(doi:), icon: 'delete', label: 'Clear abstract', data: { abstract_target: 'submit' }) %>
    </div>
  </div>
<% else %>
  <div class="invalid-feedback is-invalid d-block">
    <%= t('article_form.messages.extract_abstract_error') %>
  </div>
<% end %>
