<% content_for :breadcrumbs do %>
  <%= render Elements::BreadcrumbNavComponent.new do |component| %>
    <% component.with_breadcrumb(text: 'Dashboard', link: dashboard_path) %>
    <% component.with_breadcrumb(text: 'Admin dashboard', link: admin_dashboard_path) %>
    <% component.with_breadcrumb(text: 'Generate item report') %>
  <% end %>
<% end %>

<div class="d-flex justify-content-end">
  <%= render Admin::FunctionDropdownComponent.new %>
</div>

<%= render Elements::HeadingComponent.new(level: :h1, text: 'Generate item report', classes: 'h2 mb-4') %>

<%= form_with model: @work_report_form, url: admin_work_report_path, class: 'mb-5' do |form| %>
  <%= render Elements::Forms::DatepickerComponent.new(form:, field_name: :date_created_start, help_text: 'start', label: 'Date created start', hidden_label: true, container_classes: 'ms-2') %>
  <%= render Elements::Forms::DatepickerComponent.new(form:, field_name: :date_created_end, help_text: 'end', label: 'Date created end', hidden_label: true, container_classes: 'ms-2') %>
  <%= render Elements::Forms::DatepickerComponent.new(form:, field_name: :date_modified_start, help_text: 'start', label: 'Date last modified start', hidden_label: true, container_classes: 'ms-2') %>
  <%= render Elements::Forms::DatepickerComponent.new(form:, field_name: :date_modified_end, help_text: 'end', label: 'Date last modified end', hidden_label: true, container_classes: 'ms-2') %>


  <%= form.select :collections, @collections, multiple: true %>
  <%= render Elements::Forms::SubmitComponent.new(label: 'Submit', classes: 'mt-4') %>
<% end %>
