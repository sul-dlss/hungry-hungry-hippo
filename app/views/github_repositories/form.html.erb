<% content_for :breadcrumbs do %>
  <%= render SdrViewComponents::Elements::BreadcrumbNavComponent.new do |component| %>
    <% component.with_breadcrumb(text: 'Dashboard', link: dashboard_path) %>
    <% component.with_collection_breadcrumb(text: @collection.title, link: collection_path(@collection.druid)) %>
    <% component.with_breadcrumb(text: 'Select GitHub repository to deposit') %>
  <% end %>
<% end %>

<%= render SdrViewComponents::Elements::HeadingComponent.new(level: :h1, text: 'Deposit your GitHub repository') %>
<p class="mb-5">
  This form will allow you to set up automatic deposits of GitHub repository releases.
</p>

<%= form_with(model: @github_repository_form, data: { controller: 'form-invalid-focus' }) do |form| %>
  <%= form.hidden_field(:collection_druid) %>

  <%= render Elements::Forms::TextFieldComponent.new(form:, field_name: :repository, label: 'Enter the link or owner/name of the GitHub repository you want to deposit', mark_required: true, label_classes: 'fw-bold') %>

  <div class="d-flex my-5">
    <%= render Elements::CancelButtonComponent.new(link: collection_path(@collection.druid), classes: 'me-2') %>
    <%= render Elements::Forms::SubmitComponent.new(label: 'Next') %>
  </div>
<% end %>
